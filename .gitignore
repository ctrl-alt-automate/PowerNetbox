# Generated reference docs (CI copies from docs-build/generated/reference/ before build)
# Ignore the generated per-module subdirectories, but track the two handwritten files.
# Note: a directory-level ignore prevents all negations inside it, so we ignore
# per-module subdirs individually rather than the parent directory.
docs/reference/DCIM/
docs/reference/IPAM/
docs/reference/Virtualization/
docs/reference/Circuits/
docs/reference/Tenancy/
docs/reference/VPN/
docs/reference/Wireless/
docs/reference/Extras/
docs/reference/Users/
docs/reference/Core/
docs/reference/Setup/
docs/reference/Helpers/
docs/reference/Plugins/

# Dev-only files (exclude from main branch merges)
